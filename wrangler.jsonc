{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bleeps-agent",
  "main": "src/server.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],

  "ai": { "binding": "AI" },

  "assets": {
    "not_found_handling": "single-page-application",
    // The Worker handles the agent WebSocket/HTTP routes; everything
    // else falls through to the static React app.
    "run_worker_first": ["/agents/*"]
  },

  "durable_objects": {
    "bindings": [
      {
        "class_name": "Bleeps",
        "name": "Bleeps"
      }
    ]
  },

  "migrations": [
    // v1 — created the original `MilesGPT` class. Deleted in v2.
    {
      "tag": "v1",
      "new_sqlite_classes": ["MilesGPT"]
    },
    // v2 — renamed to `Nimbus`; wiped accumulated test pollution.
    {
      "tag": "v2",
      "deleted_classes": ["MilesGPT"],
      "new_sqlite_classes": ["Nimbus"]
    },
    // v3 — renamed to `Bleeps`; the gonimbus.ai naming collision made the
    // earlier "Nimbus" choice less appealing.
    {
      "tag": "v3",
      "deleted_classes": ["Nimbus"],
      "new_sqlite_classes": ["Bleeps"]
    }
  ]
}
